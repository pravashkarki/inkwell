{
  "typography": {
    "fontFamily": "\"Iowan Old Style\", \"Palatino Linotype\", Palatino, Georgia, \"Times New Roman\", serif",
    "fontSize": "1.5rem",
    "lineHeight": "1.3",
    "small": "0.875rem",
    "code": "0.9em"
  },
  "spacing": {
