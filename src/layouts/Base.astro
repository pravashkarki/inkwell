---
import "../styles/global.css";
import { site, nav, colors, tokens_ as t } from "../config";

interface Props {
  title: string;
  description?: string;
  mdUrl?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description, mdUrl, image, canonicalUrl } = Astro.props;
const pageUrl = canonicalUrl || new URL(Astro.url.pathname, site.url).href;
const ogImage = image ? new URL(image, site.url).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={mdUrl ? "article" : "website"} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {mdUrl && <link rel="alternate" type="text/markdown" href={mdUrl} />}
    <style set:html={`
      :root {
        --text: ${colors.light.text};
        --text-muted: ${colors.light.textMuted};
        --bg: ${colors.light.bg};
        --link: ${colors.light.link};
        --border: ${colors.light.border};
        --code-bg: ${colors.light.codeBg};
        --font-family: ${t.typography.fontFamily[t.typography.fontStack as keyof typeof t.typography.fontFamily]};
        --font-sm: ${t.typography.scale.sm};
        --font-md: ${t.typography.scale.md};
        --font-lg: ${t.typography.scale.lg};
        --font-xl: ${t.typography.scale.xl};
        --font-body: var(--font-${t.typography.body});
        --line-height: ${t.typography.lineHeight};
        --font-code: var(--font-${t.typography.code});
        --spacing-body: ${t.spacing.body};
        --max-width: ${t.spacing.maxWidth};
        --spacing-main-top: ${t.spacing.mainTop};
        --spacing-list-gap: ${t.spacing.listGap};
        --spacing-content-gap: ${t.spacing.contentGap};
        --spacing-heading-top-lg: ${t.spacing.headingTopLg};
        --spacing-heading-top-sm: ${t.spacing.headingTopSm};
        --spacing-heading-bottom: ${t.spacing.headingBottom};
        --radius-code: ${t.radii.code};
        --radius-pre: ${t.radii.pre};
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --text: ${colors.dark.text};
          --text-muted: ${colors.dark.textMuted};
          --bg: ${colors.dark.bg};
          --link: ${colors.dark.link};
          --border: ${colors.dark.border};
          --code-bg: ${colors.dark.codeBg};
        }
      }
    `} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header>
      <nav aria-label="Site">
        <a href="/">{site.name}</a>
        {nav.length > 0 && (
          <ul class="nav-links">
            {nav.map((link: { label: string; href: string; external?: boolean }) => (
              <li>
                <a
                  href={link.href}
                  {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      <p>The only way to deal with an unfree world is to become so absolutely free that your very existence is an act of rebellion.</p>
    </footer>
    <script>
      document.querySelectorAll('article pre').forEach((pre) => {
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.textContent = 'copy';
        btn.setAttribute('aria-label', 'Copy code to clipboard');
        btn.addEventListener('click', () => {
          const code = pre.querySelector('code');
          navigator.clipboard.writeText((code || pre).textContent || '').then(() => {
            btn.textContent = 'copied';
            setTimeout(() => btn.textContent = 'copy', 1500);
          });
        });
        pre.appendChild(btn);
      });
    </script>
  </body>
</html>
