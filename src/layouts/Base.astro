---
import "../styles/global.css";
import { site, scheme, colorSchemes } from "../config";

interface Props {
  title: string;
  description?: string;
  mdUrl?: string;
}

const { title, description, mdUrl } = Astro.props;
const colors = colorSchemes[scheme];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {mdUrl && <link rel="alternate" type="text/markdown" href={mdUrl} />}
    <style set:html={`
      :root {
        --text: ${colors.light.text};
        --text-muted: ${colors.light.textMuted};
        --bg: ${colors.light.bg};
        --link: ${colors.light.link};
        --border: ${colors.light.border};
        --code-bg: ${colors.light.codeBg};
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --text: ${colors.dark.text};
          --text-muted: ${colors.dark.textMuted};
          --bg: ${colors.dark.bg};
          --link: ${colors.dark.link};
          --border: ${colors.dark.border};
          --code-bg: ${colors.dark.codeBg};
        }
      }
    `} />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">{site.name}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
