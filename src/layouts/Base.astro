---
import "../styles/global.css";
import { site, colorSchemes, defaultScheme } from "../config";

interface Props {
  title: string;
  description?: string;
  mdUrl?: string;
}

const { title, description, mdUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {mdUrl && <link rel="alternate" type="text/markdown" href={mdUrl} />}
  </head>
  <body>
    <header>
      <nav>
        <a href="/">{site.name}</a>
        <theme-picker>
          <select aria-label="Color scheme">
            {Object.entries(colorSchemes).map(([key, scheme]) => (
              <option value={key}>{scheme.label}</option>
            ))}
          </select>
        </theme-picker>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <script define:vars={{ colorSchemes, defaultScheme }}>
      const picker = document.querySelector("theme-picker select");
      const saved = localStorage.getItem("color-scheme") || defaultScheme;

      function applyScheme(name) {
        const scheme = colorSchemes[name];
        if (!scheme) return;
        const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const colors = isDark ? scheme.dark : scheme.light;
        const root = document.documentElement;
        root.style.setProperty("--text", colors.text);
        root.style.setProperty("--text-muted", colors.textMuted);
        root.style.setProperty("--bg", colors.bg);
        root.style.setProperty("--link", colors.link);
        root.style.setProperty("--border", colors.border);
        root.style.setProperty("--code-bg", colors.codeBg);
      }

      picker.value = saved;
      applyScheme(saved);

      picker.addEventListener("change", (e) => {
        const name = e.target.value;
        localStorage.setItem("color-scheme", name);
        applyScheme(name);
      });

      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
        applyScheme(picker.value);
      });
    </script>
  </body>
</html>
