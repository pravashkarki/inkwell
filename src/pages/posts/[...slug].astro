---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  })).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] || null,
      next: posts[i - 1] || null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const mdUrl = `/posts/${post.id}.md`;

const words = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.round(words / 238));
---

<Base title={post.data.title} description={post.data.description} mdUrl={mdUrl} image={post.data.image} canonicalUrl={post.data.canonicalUrl} slug={post.id}>
  <article class="post-content">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <time datetime={post.data.date.toISOString().slice(0, 10)}>
        {post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
      <span class="reading-time">{readingTime} min read</span>
      {post.data.tags.length > 0 && (
        <span class="post-tags">
          {post.data.tags.map((tag: string) => (
            <a href={`/tags/${tag}/`} class="tag">{tag}</a>
          ))}
        </span>
      )}
    </div>
    <Content />
  </article>
  <nav class="post-nav" aria-label="Post navigation">
    {prev && (
      <div class="post-nav-link post-nav-prev">
        <span class="post-nav-label">Previous</span>
        <a href={`/posts/${prev.id}/`} class="post-nav-title">{prev.data.title}</a>
      </div>
    )}
    {next && (
      <div class="post-nav-link post-nav-next">
        <span class="post-nav-label">Next</span>
        <a href={`/posts/${next.id}/`} class="post-nav-title">{next.data.title}</a>
      </div>
    )}
  </nav>
</Base>
